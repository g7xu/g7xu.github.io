---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  category: string;
  coverImage?: string;
  slug: string;
  author: { name: string; avatar: string };
}

const { title, excerpt, date, category, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<li class="blog-list__item" data-category={category}>
  <time datetime={date} class="blog-list__date">{formattedDate}</time>
  <div class="blog-list__body">
    <h2 class="blog-list__title">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h2>
    <p class="blog-list__excerpt">{excerpt}</p>
    <span class="blog-list__category">{category}</span>
  </div>
</li>
