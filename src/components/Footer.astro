---
import { author } from '../data/author';
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p class="site-footer__copy">
      &copy; {new Date().getFullYear()} {author.name}
    </p>
    <p class="site-footer__attribution">
      <a href="https://www.flaticon.com/free-icons/goat" title="goat icons">Bharal icons created by Chanut-is-Industries - Flaticon</a>
    </p>
    <nav class="site-footer__links" aria-label="Footer links">
      {author.links.map(link => (
        link.url.startsWith('mailto:') ? (
          <a
            href="#"
            class="copy-email"
            data-email={link.url.replace('mailto:', '')}
            role="button"
          >
            {link.label}
          </a>
        ) : (
          <a
            href={link.url}
            target={link.url.startsWith('http') ? '_blank' : '_self'}
            rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-color, #e9ecef);
    margin-top: 4rem;
    padding: 2rem 1.5rem;
    font-size: 0.875rem;
    color: var(--secondary-color, #6c757d);
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-footer__copy {
    margin: 0;
  }

  .site-footer__attribution {
    margin: 0;
    font-size: 0.75rem;
  }

  .site-footer__attribution a {
    color: var(--secondary-color, #6c757d);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__attribution a:hover {
    color: var(--primary-color, #007acc);
  }

  .site-footer__links {
    display: flex;
    gap: 1rem;
  }

  .site-footer__links a {
    color: var(--secondary-color, #6c757d);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__links a:hover {
    color: var(--primary-color, #007acc);
  }
</style>
