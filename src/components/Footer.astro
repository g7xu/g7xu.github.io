---
import { author } from '../data/author';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <nav class="site-footer__social" aria-label="Social">
      {
        author.links.map((link) =>
          link.url.startsWith('mailto:') ? (
            <a
              href="#"
              class="copy-email"
              data-email={link.url.replace('mailto:', '')}
              role="button"
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.url}
              target={link.url.startsWith('http') ? '_blank' : '_self'}
              rel={
                link.url.startsWith('http') ? 'noopener noreferrer' : undefined
              }
            >
              {link.label}
            </a>
          ),
        )
      }
    </nav>
    <p class="site-footer__colophon">
      &copy; {year}
      {author.name}. Built with
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer"
        >Astro</a
      > /
      <a
        href="https://pages.github.com"
        target="_blank"
        rel="noopener noreferrer">GitHub Pages</a
      > /
      <a
        href="https://www.flaticon.com/free-icons/goat"
        target="_blank"
        rel="noopener noreferrer">Bharal icons</a
      >.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
    padding: 2rem 1.5rem 3rem;
  }

  .site-footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-size: 0.95rem;
  }

  .site-footer__social a {
    color: var(--fg);
    text-decoration: none;
  }

  .site-footer__social a:hover {
    color: var(--link-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer__colophon {
    margin: 0;
    font-size: 0.85rem;
    color: var(--fg-muted);
    opacity: 0.85;
    line-height: 1.5;
  }

  .site-footer__colophon a {
    color: var(--fg-muted);
    text-decoration: none;
  }

  .site-footer__colophon a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
