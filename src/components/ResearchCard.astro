---
import type { ResearchProject } from '../data/projects';

interface Props {
  research: ResearchProject;
}

const { research } = Astro.props;
---

<div
  class="research-item"
  onclick={`window.open('${research.study_url}', '_blank')`}
  style="cursor: pointer"
  role="button"
  tabindex="0"
>
  <img src={research.image} alt={research.title} loading="lazy" />
  <h3>{research.title}</h3>
  <p style="font-size: 0.9em; line-height: 1.2em; margin: 5px 0;">
    <a href={research.paper_url} style="text-decoration: none; font-weight: bold;" onclick="event.stopPropagation()">Paper</a>
    {' | '}
    <a href={research.study_url} style="text-decoration: none; font-weight: bold;" onclick="event.stopPropagation()">Study Material</a>
  </p>
  <p class="description">{research.description}</p>
  <p class="description"><strong>Tags:</strong> {research.tags.join(', ')}</p>
</div>
