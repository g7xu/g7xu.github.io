---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Learning Wiki">
  <main style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem;">
    <blockquote style="border-left: 4px solid #007acc; padding-left: 1rem; font-style: italic; color: #6c757d; margin-bottom: 2rem;">
      <p>
        Gaining success without becoming arrogant, facing setbacks without becoming disheartened,
        and working diligently every single day—this is more important than anything else.
      </p>
      <footer>— Kazuo Inamori</footer>
    </blockquote>

    <h1>Courses</h1>
    <hr />
    <div class="course-flex">
      <div
        class="course-item"
        onclick="location.href='/learning_wiki/data_visualization/'"
        style="cursor: pointer;"
      >
        <img
          src="https://vis-society.github.io/labs/2/images/empty.svg"
          alt="Image on data visualization"
        />
        <div class="course-content">
          <h3>DSC 106: Data Visualization</h3>
          <p><strong>Description:</strong> Data visualization taught by Sam Lau in UCSD</p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
